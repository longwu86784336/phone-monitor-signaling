<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1a1a2e"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <!-- 标题 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="手机监控"
            android:textColor="#c9ada7"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvDeviceId"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="设备ID: ----"
            android:textColor="#4a4e69"
            android:textSize="14sp"
            android:layout_marginBottom="24dp" />

        <!-- 服务器地址 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="服务器地址"
            android:textColor="#c9ada7"
            android:textSize="14sp"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/etServer"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="#2d2d44"
            android:textColor="#ffffff"
            android:textColorHint="#666688"
            android:hint="phone-monitor-server.onrender.com"
            android:padding="12dp"
            android:inputType="textUri"
            android:layout_marginBottom="16dp"
            android:focusable="true"
            android:focusableInTouchMode="true" />

        <!-- 密码 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="访问密码"
            android:textColor="#c9ada7"
            android:textSize="14sp"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/etPassword"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="#2d2d44"
            android:textColor="#ffffff"
            android:textColorHint="#666688"
            android:hint="请输入密码"
            android:padding="12dp"
            android:inputType="textPassword"
            android:layout_marginBottom="8dp"
            android:focusable="true"
            android:focusableInTouchMode="true" />

        <!-- 记住密码 + 自动启动 -->
        <CheckBox
            android:id="@+id/cbRemember"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="记住密码，下次自动启动监控"
            android:textColor="#c9ada7"
            android:textSize="13sp"
            android:buttonTint="#4a6cf7"
            android:layout_marginBottom="16dp" />

        <!-- 启动按钮 -->
        <Button
            android:id="@+id/btnStart"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="启动监控"
            android:textColor="#ffffff"
            android:backgroundTint="#4a4e69"
            android:layout_marginBottom="8dp" />

        <!-- 停止监控按钮 -->
        <Button
            android:id="@+id/btnStop"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="停止监控"
            android:textColor="#ffffff"
            android:backgroundTint="#8b0000"
            android:layout_marginBottom="16dp"
            android:visibility="gone" />

        <!-- ★ 红外/夜视模式切换（仅服务运行时可见） -->
        <LinearLayout
            android:id="@+id/llSpecialModes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:visibility="gone"
            android:layout_marginBottom="16dp">

            <Button
                android:id="@+id/btnInfrared"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="🌙 红外"
                android:textColor="#ffffff"
                android:textSize="13sp"
                android:backgroundTint="#444466"
                android:layout_marginEnd="4dp" />

            <Button
                android:id="@+id/btnNightVision"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="👁 夜视"
                android:textColor="#ffffff"
                android:textSize="13sp"
                android:backgroundTint="#444466"
                android:layout_marginStart="4dp" />
        </LinearLayout>

        <!-- 状态 -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="等待启动..."
            android:textColor="#4a4e69"
            android:textSize="12sp"
            android:gravity="center"
            android:layout_marginBottom="16dp" />

        <!-- 二维码 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="扫码连接"
            android:textColor="#c9ada7"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <ImageView
            android:id="@+id/ivQrCode"
            android:layout_width="256dp"
            android:layout_height="256dp"
            android:background="#ffffff"
            android:padding="8dp"
            android:scaleType="fitCenter"
            android:layout_marginBottom="24dp"
            android:contentDescription="扫描此二维码连接监控" />

        <!-- 版本号 -->
        <TextView
            android:id="@+id/tvVersion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="v2.6.0"
            android:textColor="#555577"
            android:textSize="11sp"
            android:layout_marginBottom="16dp" />

    </LinearLayout>
</ScrollView>
